# =============================================================================
# GEA EOR SaaS Admin - 环境变量配置文件
# =============================================================================
# 复制此文件为 .env 并根据实际情况填写配置值
# 所有敏感信息请务必在生产环境中妥善保管，不要提交到代码仓库
# =============================================================================

# -----------------------------------------------------------------------------
# 核心配置 (必填)
# -----------------------------------------------------------------------------

# 数据库连接字符串
# 本地开发: file:./sqlite.db
# 生产环境: libsql://your-db.turso.io?authToken=your-token
DATABASE_URL=

# JWT 密钥 (用于签名和验证认证 Token)
# 生产环境请使用强随机字符串，例如: openssl rand -hex 32
JWT_SECRET=

# 运行环境
# 可选值: development | production | test
NODE_ENV=development

# 服务器端口
PORT=3000

# -----------------------------------------------------------------------------
# 管理员引导配置 (首次启动使用)
# -----------------------------------------------------------------------------

# 默认管理员邮箱
ADMIN_BOOTSTRAP_EMAIL=simon.ding@geahr.com

# 默认管理员姓名
ADMIN_BOOTSTRAP_NAME=Simon Ding

# 默认管理员密码 (生产环境必填，开发环境可选)
# 生产环境请设置强密码，首次启动后建议立即修改
ADMIN_BOOTSTRAP_PASSWORD=

# -----------------------------------------------------------------------------
# 对象存储配置 (可选，用于文件上传)
# -----------------------------------------------------------------------------
# 支持阿里云 OSS 或兼容 S3 的对象存储服务

# 访问密钥 ID
OSS_ACCESS_KEY_ID=

# 访问密钥 Secret
OSS_ACCESS_KEY_SECRET=

# 区域
OSS_REGION=

# Bucket 名称
OSS_BUCKET=

# 端点 (可选，用于非阿里云 OSS)
OSS_ENDPOINT=

# -----------------------------------------------------------------------------
# 邮件配置 (可选，用于发送通知)
# -----------------------------------------------------------------------------

# SMTP 服务器地址
EMAIL_SMTP_HOST=

# SMTP 端口 (465 为 SSL，587 为 STARTTLS)
EMAIL_SMTP_PORT=465

# SMTP 用户名
EMAIL_SMTP_USER=

# SMTP 密码
EMAIL_SMTP_PASS=

# 发件人地址
EMAIL_FROM=no-reply@geahr.com

# 管理员收件人地址
EMAIL_ADMIN=admin@geahr.com

# -----------------------------------------------------------------------------
# AI 配置 (可选，用于 Copilot 和 AI 功能)
# -----------------------------------------------------------------------------

# 阿里云 DashScope (通义千问) API Key
DASHSCOPE_API_KEY=

# -----------------------------------------------------------------------------
# 遗留配置 (即将移除，无需配置)
# -----------------------------------------------------------------------------

# Manus OAuth (已弃用，使用本地密码认证)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
OAUTH_SERVER_URL=

# AWS S3 (已弃用，使用 OSS_* 配置)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# TiDB (已弃用，使用 DATABASE_URL)
DATABASE_AUTH_TOKEN=

# Manus Forge (已弃用)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_APP_ID=

