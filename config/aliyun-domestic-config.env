# 阿里云国内节点环境配置
# 适用于个人开发者测试环境

# === 基础配置 ===
NODE_ENV=production
PORT=3000
JWT_SECRET=your-strong-jwt-secret-key-here

# === 阿里云RDS MySQL ===
# 建议使用阿里云RDS而非本地MySQL
DATABASE_URL=mysql://username:password@rm-xxxxxx.mysql.rds.aliyuncs.com:3306/gea_eor_db

# === 阿里云OSS配置 ===
# 使用国内节点的OSS
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_REGION=oss-cn-beijing
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com

# === 阿里云DirectMail ===
EMAIL_SMTP_HOST=smtpdm.aliyun.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=your-email@your-domain.com
EMAIL_SMTP_PASS=your-email-password
EMAIL_FROM=noreply@your-domain.com
EMAIL_ADMIN=admin@your-domain.com

# === 阿里云DashScope AI ===
# 通义千问，国内节点推荐
DASHSCOPE_API_KEY=your-dashscope-api-key

# === 系统配置 ===
# 国内节点建议使用人民币作为默认货币
DEFAULT_CURRENCY=CNY
DEFAULT_TIMEZONE=Asia/Shanghai

# === 安全配置 ===
# 国内环境建议使用HTTPS
FORCE_HTTPS=true
CORS_ORIGIN=https://your-domain.com